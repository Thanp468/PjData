<!doctype html>
<html lang="th" class="h-full">
 <head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>University Management System</title>
  <script src="https://cdn.tailwindcss.com/3.4.17"></script>
  <script src="/_sdk/element_sdk.js"></script>
  <script src="/_sdk/data_sdk.js"></script>
  <link href="https://fonts.googleapis.com/css2?family=Prompt:wght@300;400;500;600;700&amp;display=swap" rel="stylesheet">
  <style>
    * { font-family: 'Prompt', sans-serif; }
    .glass { background: rgba(255,255,255,0.95); backdrop-filter: blur(10px); }
    .gradient-bg { background: linear-gradient(135deg, #667eea 0%, #764ba2 50%, #f093fb 100%); }
    .card-hover { transition: all 0.3s ease; }
    .card-hover:hover { transform: translateY(-4px); box-shadow: 0 12px 40px rgba(102,126,234,0.3); }
    .sidebar-item { transition: all 0.2s ease; }
    .sidebar-item:hover { background: rgba(102,126,234,0.1); }
    .sidebar-item.active { background: linear-gradient(90deg, #667eea, #764ba2); color: white; }
    .stat-card { background: linear-gradient(135deg, rgba(102,126,234,0.1), rgba(118,75,162,0.1)); }
    .progress-bar { background: linear-gradient(90deg, #667eea, #764ba2); }
    .notification-badge { animation: pulse 2s infinite; }
    @keyframes pulse { 0%, 100% { opacity: 1; } 50% { opacity: 0.7; } }
    .fade-in { animation: fadeIn 0.3s ease; }
    @keyframes fadeIn { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }
    .scroll-area { scrollbar-width: thin; scrollbar-color: #667eea #f1f1f1; }
    .scroll-area::-webkit-scrollbar { width: 6px; }
    .scroll-area::-webkit-scrollbar-track { background: #f1f1f1; border-radius: 3px; }
    .scroll-area::-webkit-scrollbar-thumb { background: #667eea; border-radius: 3px; }
    input:focus, select:focus, textarea:focus { outline: none; box-shadow: 0 0 0 3px rgba(102,126,234,0.3); }
    .todo-item { border-left: 4px solid transparent; }
    .todo-item.high { border-left-color: #ef4444; }
    .todo-item.medium { border-left-color: #f59e0b; }
    .todo-item.low { border-left-color: #10b981; }
  </style>
  <style>body { box-sizing: border-box; }</style>
 </head>
 <body class="h-full bg-gray-50">
  <div id="app" class="h-full overflow-auto"><!-- Login Page -->
   <div id="login-page" class="min-h-full gradient-bg flex items-center justify-center p-4">
