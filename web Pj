      if (users.length === 0) {
        container.innerHTML = '<tr><td colspan="5" class="text-center py-8 text-gray-500">ไม่พบผู้ใช้</td></tr>';
      } else {
        container.innerHTML = users.map(u => `
          <tr class="border-b">
            <td class="px-4 py-3">${u.name || '-'}</td>
            <td class="px-4 py-3 text-sm">${u.email || '-'}</td>
            <td class="px-4 py-3 text-center">
              <span class="px-2 py-1 text-xs rounded-lg ${
                u.user_type === 'teacher' ? 'bg-purple-100 text-purple-600' :
                u.user_type === 'admin' ? 'bg-red-100 text-red-600' :
                'bg-blue-100 text-blue-600'
              }">${
                u.user_type === 'teacher' ? 'อาจารย์' :
                u.user_type === 'admin' ? 'ผู้ดูแล' : 'นักศึกษา'
              }</span>
            </td>
            <td class="px-4 py-3 text-center text-sm">${u.faculty || '-'}</td>
            <td class="px-4 py-3 text-center">
              <button onclick="deleteUser('${u.__backendId}')" class="p-1 text-red-400 hover:text-red-600">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
              </button>
            </td>
          </tr>
        `).join('');
      }
    }

    async function deleteUser(id) {
      const user = allData.find(d => d.__backendId === id);
      if (user && user.__backendId !== currentUser?.__backendId) {
        await window.dataSdk.delete(user);
      }
    }

    function renderManageCourses() {
      const container = document.getElementById('admin-courses-list');
      const courses = allData.filter(d => d.type === 'course');
      
      if (courses.length === 0) {
        container.innerHTML = '<p class="text-gray-500 text-sm text-center py-4">ยังไม่มีรายวิชา</p>';
      } else {
        container.innerHTML = courses.map(c => `
          <div class="flex items-center justify-between p-4 bg-gray-50 rounded-xl">
            <div>
              <p class="font-medium text-gray-800">${c.subject_code} - ${c.subject_name}</p>
              <p class="text-sm text-gray-500">${c.credits} หน่วยกิต | ${c.instructor || '-'}</p>
            </div>
            <button onclick="deleteCourse('${c.__backendId}')" class="p-2 text-red-400 hover:text-red-600">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
            </button>
          </div>
        `).join('');
      }
    }

    async function deleteCourse(id) {
      const course = allData.find(d => d.__backendId === id);
      if (course) {
        await window.dataSdk.delete(course);
      }
    }

    function renderManageFaculty() {
      // Faculty list
      const facultyContainer = document.getElementById('faculty-list');
      facultyContainer.innerHTML = Object.keys(facultyDepartments).map(f => `
        <div class="flex items-center justify-between p-2 bg-gray-50 rounded-lg text-sm">
          <span>${f}</span>
        </div>
      `).join('');
      
      // Department select
      const deptFacultySelect = document.getElementById('dept-faculty-select');
      deptFacultySelect.innerHTML = '<option value="">-- เลือกคณะ --</option>' +
        Object.keys(facultyDepartments).map(f => `<option value="${f}">${f}</option>`).join('');
      
      // Department list
      const deptContainer = document.getElementById('department-list');
      let allDepts = [];
      Object.entries(facultyDepartments).forEach(([fac, depts]) => {
        depts.forEach(d => allDepts.push({ faculty: fac, name: d }));
      });
      deptContainer.innerHTML = allDepts.slice(0, 10).map(d => `
        <div class="flex items-center justify-between p-2 bg-gray-50 rounded-lg text-sm">
          <span>${d.name}</span>
          <span class="text-xs text-gray-400">${d.faculty}</span>
        </div>
      `).join('');
    }

    function setTeacherRating(rating) {
      teacherRating = rating;
      updateRatingStars('teacher-rating', rating);
    }

    function setCourseRating(rating) {
      courseRating = rating;
      updateRatingStars('course-rating', rating);
    }

    function updateRatingStars(containerId, rating) {
      const container = document.getElementById(containerId);
      const stars = container.querySelectorAll('button');
      stars.forEach((star, i) => {
        star.classList.toggle('text-yellow-400', i < rating);
        star.classList.toggle('text-gray-300', i >= rating);
      });
    }

    function searchCourseForReg() {
      const code = document.getElementById('reg-course-code').value;
      const container = document.getElementById('reg-search-results');
      const courses = allData.filter(d => d.type === 'course' && d.subject_code?.includes(code));
      
      if (courses.length === 0) {
        container.innerHTML = '<p class="text-gray-500 text-sm text-center py-4">ไม่พบรายวิชา</p>';
      } else {
        container.innerHTML = courses.map(c => `
          <div class="flex items-center justify-between p-4 bg-gray-50 rounded-xl">
            <div>
              <p class="font-medium text-gray-800">${c.subject_code} - ${c.subject_name}</p>
              <p class="text-sm text-gray-500">${c.credits} หน่วยกิต | ว่าง ${c.capacity - (c.enrolled || 0)}/${c.capacity} ที่นั่ง</p>
            </div>
            <button onclick="enrollCourse('${c.__backendId}')" class="px-4 py-2 rounded-xl gradient-bg text-white text-sm font-medium">ลงทะเบียน</button>
          </div>
        `).join('');
      }
    }

    async function enrollCourse(id) {
      if (!currentUser) return;
      
      const course = allData.find(d => d.__backendId === id);
      if (course) {
        await window.dataSdk.create({
          type: 'enrollment',
          user_id: currentUser.__backendId,
          subject_code: course.subject_code,
          subject_name: course.subject_name,
          credits: course.credits,
          semester: '1/2567',
          status: 'enrolled',
          created_at: new Date().toISOString()
        });
        
        // Update course enrolled count
        await window.dataSdk.update({
          ...course,
          enrolled: (course.enrolled || 0) + 1
        });
      }
    }

    function formatDate(dateStr) {
      if (!dateStr) return '-';
      const date = new Date(dateStr);
      return date.toLocaleDateString('th-TH', { day: 'numeric', month: 'short', year: 'numeric' });
    }

    // ===================== FILTERS =====================
    document.getElementById('course-filter-type')?.addEventListener('change', renderCourses);
    document.getElementById('course-search')?.addEventListener('input', renderCourses);
    document.getElementById('notif-type-filter')?.addEventListener('change', renderNotifications);
    document.getElementById('assignment-status-filter')?.addEventListener('change', renderAssignments);
    document.getElementById('event-type-filter')?.addEventListener('change', renderEvents);

    // ===================== INIT =====================
    initSDKs();
    applyConfig();
  </script>
