      <p class="text-gray-500">กรอกข้อมูลเพื่อสร้างบัญชี</p>
     </div>
     <form id="register-form" class="space-y-4">
      <div><label class="block text-sm font-medium text-gray-700 mb-1">ชื่อ-นามสกุล</label> <input type="text" id="reg-name" required class="w-full px-4 py-3 rounded-xl border border-gray-200" placeholder="ชื่อ นามสกุล">
      </div>
      <div><label class="block text-sm font-medium text-gray-700 mb-1">ประเภทผู้ใช้</label> <select id="reg-usertype" required class="w-full px-4 py-3 rounded-xl border border-gray-200 bg-white"> <option value="">-- เลือกประเภท --</option> <option value="student">นักศึกษา</option> <option value="teacher">อาจารย์</option> </select>
      </div>
      <div><label class="block text-sm font-medium text-gray-700 mb-1">คณะ</label> <select id="reg-faculty" required class="w-full px-4 py-3 rounded-xl border border-gray-200 bg-white"> <option value="">-- เลือกคณะ --</option> </select>
      </div>
