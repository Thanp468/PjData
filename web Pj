  <script>
    // ===================== CONFIG & STATE =====================
    const defaultConfig = {
      app_title: 'University Management',
      university_name: 'ระบบจัดการการศึกษา',
      primary_color: '#667eea',
      secondary_color: '#764ba2',
      accent_color: '#f093fb',
      text_color: '#1f2937',
      background_color: '#f9fafb'
    };

    let config = { ...defaultConfig };
    let allData = [];
    let currentUser = null;
    let teacherRating = 0;
    let courseRating = 0;

    // Faculty & Department Data
    const facultyDepartments = {
      'คณะวิศวกรรมศาสตร์': ['วิศวกรรมคอมพิวเตอร์', 'วิศวกรรมไฟฟ้า', 'วิศวกรรมเครื่องกล', 'วิศวกรรมโยธา', 'วิศวกรรมอุตสาหการ'],
      'คณะวิทยาศาสตร์': ['วิทยาการคอมพิวเตอร์', 'คณิตศาสตร์', 'ฟิสิกส์', 'เคมี', 'ชีววิทยา'],
      'คณะบริหารธุรกิจ': ['การจัดการ', 'การตลาด', 'การเงิน', 'การบัญชี', 'ธุรกิจระหว่างประเทศ'],
      'คณะมนุษยศาสตร์': ['ภาษาอังกฤษ', 'ภาษาไทย', 'ภาษาจีน', 'ภาษาญี่ปุ่น', 'ประวัติศาสตร์'],
      'คณะนิติศาสตร์': ['นิติศาสตร์'],
      'คณะศึกษาศาสตร์': ['การศึกษาปฐมวัย', 'การศึกษาประถมศึกษา', 'เทคโนโลยีการศึกษา'],
      'คณะสถาปัตยกรรมศาสตร์': ['สถาปัตยกรรม', 'ออกแบบภายใน', 'ภูมิสถาปัตยกรรม'],
      'คณะเกษตรศาสตร์': ['พืชศาสตร์', 'สัตวศาสตร์', 'ประมง', 'เทคโนโลยีการอาหาร']
    };

    // ===================== SDK INITIALIZATION =====================
    const dataHandler = {
      onDataChanged(data) {
        allData = data;
        renderUI();
      }
    };

    async function initSDKs() {
      // Element SDK
      if (window.elementSdk) {
        window.elementSdk.init({
          defaultConfig,
          onConfigChange: async (cfg) => {
            config = { ...defaultConfig, ...cfg };
            applyConfig();
          },
          mapToCapabilities: (cfg) => ({
            recolorables: [
              { get: () => cfg.primary_color || defaultConfig.primary_color, set: (v) => { cfg.primary_color = v; window.elementSdk.setConfig({ primary_color: v }); }},
              { get: () => cfg.background_color || defaultConfig.background_color, set: (v) => { cfg.background_color = v; window.elementSdk.setConfig({ background_color: v }); }},
              { get: () => cfg.text_color || defaultConfig.text_color, set: (v) => { cfg.text_color = v; window.elementSdk.setConfig({ text_color: v }); }}
            ],
            borderables: [],
            fontEditable: undefined,
            fontSizeable: undefined
          }),
          mapToEditPanelValues: (cfg) => new Map([
            ['app_title', cfg.app_title || defaultConfig.app_title],
            ['university_name', cfg.university_name || defaultConfig.university_name]
          ])
        });
      }

      // Data SDK
      if (window.dataSdk) {
        const result = await window.dataSdk.init(dataHandler);
        if (!result.isOk) {
          console.error('Data SDK init failed');
        }
      }
    }

    function applyConfig() {
      document.getElementById('app-title').textContent = config.app_title || defaultConfig.app_title;
      document.getElementById('university-name').textContent = config.university_name || defaultConfig.university_name;
    }

    // ===================== NAVIGATION =====================
    function showLogin() {
      document.getElementById('login-page').classList.remove('hidden');
      document.getElementById('register-page').classList.add('hidden');
      document.getElementById('dashboard').classList.add('hidden');
    }

    function showRegister() {
      document.getElementById('login-page').classList.add('hidden');
      document.getElementById('register-page').classList.remove('hidden');
      document.getElementById('dashboard').classList.add('hidden');
      populateFacultyDropdown();
    }

    function showDashboard() {
      document.getElementById('login-page').classList.add('hidden');
      document.getElementById('register-page').classList.add('hidden');
      document.getElementById('dashboard').classList.remove('hidden');
      updateUserDisplay();
      showSection('overview');
    }

    function showSection(sectionId) {
      // Hide all sections
      document.querySelectorAll('[id^="section-"]').forEach(s => s.classList.add('hidden'));
      // Show selected section
      const section = document.getElementById('section-' + sectionId);
      if (section) {
        section.classList.remove('hidden');
        section.classList.add('fade-in');
      }
      // Update sidebar active state
      document.querySelectorAll('.sidebar-item').forEach(item => {
        item.classList.remove('active');
        if (item.dataset.section === sectionId) {
          item.classList.add('active');
        }
      });
      // Update page title
      const titles = {
        'overview': 'ภาพรวม',
        'profile': 'โปรไฟล์',
        'courses': 'คลังรายวิชา',
        'registration': 'ลงทะเบียนเรียน',
        'schedule': 'ตารางเรียน',
        'grades': 'ผลการเรียน',
        'assignments': 'งานที่มอบหมาย',
        'todo': 'To-Do List',
        'notifications': 'แจ้งเตือน',
        'events': 'กิจกรรม',
        'reviews': 'รีวิวและประเมิน',
        'manage-users': 'จัดการผู้ใช้',
        'manage-courses': 'จัดการรายวิชา',
        'manage-faculty': 'จัดการคณะ/สาขา'
      };
      document.getElementById('page-title').textContent = titles[sectionId] || sectionId;
      renderSection(sectionId);
    }

    function logout() {
      currentUser = null;
      showLogin();
    }

    // ===================== REGISTRATION =====================
    function populateFacultyDropdown() {
      const facultySelect = document.getElementById('reg-faculty');
      facultySelect.innerHTML = '<option value="">-- เลือกคณะ --</option>';
      Object.keys(facultyDepartments).forEach(faculty => {
        const option = document.createElement('option');
        option.value = faculty;
        option.textContent = faculty;
        facultySelect.appendChild(option);
      });
    }

    document.getElementById('reg-faculty')?.addEventListener('change', function() {
      const deptSelect = document.getElementById('reg-department');
      const faculty = this.value;
      
      if (faculty && facultyDepartments[faculty]) {
        deptSelect.disabled = false;
        deptSelect.innerHTML = '<option value="">-- เลือกสาขา --</option>';
        facultyDepartments[faculty].forEach(dept => {
          const option = document.createElement('option');
          option.value = dept;
          option.textContent = dept;
          deptSelect.appendChild(option);
        });
      } else {
        deptSelect.disabled = true;
        deptSelect.innerHTML = '<option value="">-- เลือกคณะก่อน --</option>';
      }
    });

    document.getElementById('reg-usertype')?.addEventListener('change', function() {
      const studentIdField = document.getElementById('student-id-field');
      if (this.value === 'teacher') {
        studentIdField.style.display = 'none';
      } else {
        studentIdField.style.display = 'block';
      }
    });

    // ===================== FORM HANDLERS =====================
    document.getElementById('login-form')?.addEventListener('submit', async function(e) {
      e.preventDefault();
      const email = document.getElementById('login-email').value;
      const password = document.getElementById('login-password').value;
      
      const user = allData.find(d => d.type === 'user' && d.email === email && d.password === password);
      
      if (user) {
        currentUser = user;
        document.getElementById('login-error').classList.add('hidden');
        showDashboard();
      } else {
        document.getElementById('login-error').textContent = 'อีเมลหรือรหัสผ่านไม่ถูกต้อง';
        document.getElementById('login-error').classList.remove('hidden');
      }
    });

    document.getElementById('register-form')?.addEventListener('submit', async function(e) {
      e.preventDefault();
      
      const name = document.getElementById('reg-name').value;
      const userType = document.getElementById('reg-usertype').value;
      const faculty = document.getElementById('reg-faculty').value;
      const department = document.getElementById('reg-department').value;
      const studentId = document.getElementById('reg-studentid').value;
      const email = document.getElementById('reg-email').value;
      const password = document.getElementById('reg-password').value;
      const confirm = document.getElementById('reg-confirm').value;
      
      if (password !== confirm) {
        document.getElementById('register-error').textContent = 'รหัสผ่านไม่ตรงกัน';
        document.getElementById('register-error').classList.remove('hidden');
        return;
      }
      
      if (password.length < 6) {
        document.getElementById('register-error').textContent = 'รหัสผ่านต้องมีอย่างน้อย 6 ตัวอักษร';
        document.getElementById('register-error').classList.remove('hidden');
        return;
      }
      
      // Check existing email
      const existingUser = allData.find(d => d.type === 'user' && d.email === email);
      if (existingUser) {
        document.getElementById('register-error').textContent = 'อีเมลนี้ถูกใช้แล้ว';
        document.getElementById('register-error').classList.remove('hidden');
        return;
      }
      
      if (allData.filter(d => d.type === 'user').length >= 999) {
        document.getElementById('register-error').textContent = 'ระบบรองรับผู้ใช้สูงสุด 999 คน';
        document.getElementById('register-error').classList.remove('hidden');
        return;
      }
      
      const result = await window.dataSdk.create({
        type: 'user',
        name,
        user_type: userType,
        faculty,
        department,
        student_id: studentId,
        email,
        password,
        created_at: new Date().toISOString(),
        profile_complete: true
      });
      
      if (result.isOk) {
        document.getElementById('register-error').classList.add('hidden');
        document.getElementById('register-success').textContent = 'ลงทะเบียนสำเร็จ! กรุณาเข้าสู่ระบบ';
        document.getElementById('register-success').classList.remove('hidden');
        document.getElementById('register-form').reset();
        setTimeout(() => showLogin(), 2000);
      } else {
        document.getElementById('register-error').textContent = 'เกิดข้อผิดพลาด กรุณาลองใหม่';
        document.getElementById('register-error').classList.remove('hidden');
      }
    });

    document.getElementById('profile-form')?.addEventListener('submit', async function(e) {
      e.preventDefault();
      if (!currentUser) return;
      
      const name = document.getElementById('profile-name-input').value;
      const phone = document.getElementById('profile-phone-input').value;
      
      const result = await window.dataSdk.update({
        ...currentUser,
        name,
        phone
      });
      
      if (result.isOk) {
        currentUser.name = name;
        currentUser.phone = phone;
        updateUserDisplay();
      }
    });

   document.getElementById('todo-form')?.addEventListener('submit', async function(e) {
      e.preventDefault();
      if (!currentUser) return;
      
      const title = document.getElementById('todo-input').value;
      const priority = document.getElementById('todo-priority').value;
      
      try {
        // ยิง API ไปหา Backend ที่รันอยู่บนพอร์ต 3000
        const response = await fetch('http://localhost:3000/api/todo', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
                UserID: currentUser.__backendId, // ส่ง ID คนที่กำลัง Login
                TaskName: title,                 // ชื่องานที่พิมพ์ในช่อง
                Priority: priority               // ความสำคัญ (high, medium, low)
            })
        });

        // ถ้า Backend บันทึกลง Oracle สำเร็จ
        if (response.ok) {
            document.getElementById('todo-input').value = ''; // ล้างช่องพิมพ์
            alert('เพิ่ม To-Do สำเร็จ!');
            // อนาคตต้องเขียนฟังก์ชัน fetch ดึงรายการมาแสดงใหม่ตรงนี้
        } else {
            alert('เกิดข้อผิดพลาดในการบันทึกข้อมูล');
        }
      } catch (error) {
        console.error('API Error:', error);
        alert('ไม่สามารถเชื่อมต่อกับฐานข้อมูลได้ (ลืมเปิด Backend หรือเปล่า?)');
      }
    });
  
    document.getElementById('add-course-form')?.addEventListener('submit', async function(e) {
      e.preventDefault();
      
      const courseData = {
        type: 'course',
        subject_code: document.getElementById('new-course-code').value,
        subject_name: document.getElementById('new-course-name').value,
        credits: parseInt(document.getElementById('new-course-credits').value),
        subject_type: document.getElementById('new-course-type').value,
        instructor: document.getElementById('new-course-instructor').value,
        capacity: parseInt(document.getElementById('new-course-capacity').value),
        enrolled: 0,
        created_at: new Date().toISOString()
      };
      
      const result = await window.dataSdk.create(courseData);
      if (result.isOk) {
        this.reset();
      }
    });

    document.getElementById('teacher-review-form')?.addEventListener('submit', async function(e) {
      e.preventDefault();
      if (!currentUser || teacherRating === 0) return;
      
      const result = await window.dataSdk.create({
        type: 'review',
        user_id: currentUser.__backendId,
        related_id: document.getElementById('review-teacher').value,
        rating: teacherRating,
        review_text: document.getElementById('teacher-review-text').value,
        notification_type: 'teacher',
        created_at: new Date().toISOString()
      });
      
      if (result.isOk) {
