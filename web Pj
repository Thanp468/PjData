      </div>
      <div><label class="block text-sm font-medium text-gray-700 mb-1">อีเมล</label> <input type="email" id="reg-email" required class="w-full px-4 py-3 rounded-xl border border-gray-200" placeholder="example@university.ac.th">
      </div>
      <div><label class="block text-sm font-medium text-gray-700 mb-1">รหัสผ่าน</label> <input type="password" id="reg-password" required class="w-full px-4 py-3 rounded-xl border border-gray-200" placeholder="อย่างน้อย 6 ตัวอักษร">
      </div>
      <div><label class="block text-sm font-medium text-gray-700 mb-1">ยืนยันรหัสผ่าน</label> <input type="password" id="reg-confirm" required class="w-full px-4 py-3 rounded-xl border border-gray-200" placeholder="ยืนยันรหัสผ่าน">
      </div><button type="submit" class="w-full py-3 rounded-xl gradient-bg text-white font-semibold hover:opacity-90 transition shadow-lg"> ลงทะเบียน </button>
     </form>
