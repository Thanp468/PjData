    function updateStats() {
      if (!currentUser) return;
      
      // Get user's grades
      const grades = allData.filter(d => d.type === 'grade' && d.user_id === currentUser.__backendId);
      const enrollments = allData.filter(d => d.type === 'enrollment' && d.user_id === currentUser.__backendId);
      const assignments = allData.filter(d => d.type === 'assignment' && !d.submitted);
      
      // Calculate GPAX
      let totalPoints = 0;
      let totalCredits = 0;
      const gradePoints = { 'A': 4, 'B+': 3.5, 'B': 3, 'C+': 2.5, 'C': 2, 'D+': 1.5, 'D': 1, 'F': 0 };
      
      grades.forEach(g => {
        if (gradePoints[g.grade] !== undefined && g.credits) {
          totalPoints += gradePoints[g.grade] * g.credits;
          totalCredits += g.credits;
        }
      });
      
      const gpax = totalCredits > 0 ? (totalPoints / totalCredits).toFixed(2) : '0.00';
      
      document.getElementById('stat-credits').textContent = `${totalCredits}/120`;
      document.getElementById('credits-progress').style.width = `${(totalCredits/120)*100}%`;
      document.getElementById('stat-gpax').textContent = gpax;
      document.getElementById('stat-pending').textContent = assignments.length;
      document.getElementById('stat-courses').textContent = enrollments.length;
      
      document.getElementById('grades-gpax').textContent = gpax;
      document.getElementById('grades-credits').textContent = totalCredits;
      
      // Calculate GPA by type
      const coreGrades = grades.filter(g => g.subject_type === 'core');
      const electiveGrades = grades.filter(g => g.subject_type === 'elective');
      const geGrades = grades.filter(g => g.subject_type === 'ge');
      
      document.getElementById('core-gpa').textContent = calculateGPA(coreGrades);
      document.getElementById('elective-gpa').textContent = calculateGPA(electiveGrades);
      document.getElementById('ge-gpa').textContent = calculateGPA(geGrades);
    }

    function calculateGPA(grades) {
      const gradePoints = { 'A': 4, 'B+': 3.5, 'B': 3, 'C+': 2.5, 'C': 2, 'D+': 1.5, 'D': 1, 'F': 0 };
      let points = 0, credits = 0;
      grades.forEach(g => {
        if (gradePoints[g.grade] !== undefined && g.credits) {
          points += gradePoints[g.grade] * g.credits;
          credits += g.credits;
        }
      });
      return credits > 0 ? (points / credits).toFixed(2) : '0.00';
    }

